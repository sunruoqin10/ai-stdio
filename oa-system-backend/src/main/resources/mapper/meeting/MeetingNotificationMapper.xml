<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.oa_system_backend.module.meeting.mapper.MeetingNotificationMapper">

    <resultMap id="BaseResultMap" type="com.example.oa_system_backend.module.meeting.entity.MeetingNotification">
        <id column="id" property="id"/>
        <result column="recipient_id" property="recipientId"/>
        <result column="recipient_name" property="recipientName"/>
        <result column="type" property="type"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="booking_id" property="bookingId"/>
        <result column="is_read" property="isRead"/>
        <result column="read_at" property="readAt"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="selectByRecipientId" resultMap="BaseResultMap">
        SELECT * FROM meeting_notification
        WHERE recipient_id = #{recipientId}
        ORDER BY created_at DESC
    </select>

    <update id="markAsRead">
        UPDATE meeting_notification
        SET is_read = 1, read_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>
