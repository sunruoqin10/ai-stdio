<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.oa_system_backend.module.meeting.mapper.MeetingRoomMapper">

    <resultMap id="BaseResultMap" type="com.example.oa_system_backend.module.meeting.entity.MeetingRoom">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="location" property="location"/>
        <result column="capacity" property="capacity"/>
        <result column="floor" property="floor"/>
        <result column="area" property="area"/>
        <result column="facilities" property="facilities"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="images" property="images"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectPageByCondition" resultMap="BaseResultMap">
        SELECT * FROM admin_meeting_room
        WHERE 1=1
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        AND status != 'disabled'
        ORDER BY id ASC
    </select>

    <select id="countActiveBookings" resultType="java.lang.Long">
        SELECT COUNT(*) FROM admin_meeting_booking
        WHERE room_id = #{roomId}
          AND status NOT IN ('cancelled', 'rejected')
          AND start_time >= NOW()
    </select>

</mapper>
